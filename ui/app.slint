import {
    ListView,
    ComboBox,
    Slider,
    LineEdit,
    Switch,
    Palette,
} from "std-widgets.slint";
import { ControlPanel } from "control_panel.slint";
import { Sidebar } from "sidebar.slint";
import { SpectrumView } from "spectrum.slint";
import { LyricsPanel } from "lyrics_panel.slint";
import { TitleBar, SongItem, SongListView } from "song_list.slint";
import { SettingsPanel } from "settings_panel.slint";
import {
    PlayMode,
    LyricItem,
    SongInfo,
    SortKey,
    TriggerSource,
} from "types.slint";
import "msyhl.ttc";

export { PlayMode, LyricItem, SongInfo, SortKey, TriggerSource }

// ui state
export global UIState {
    // 当前播放进度 (秒)
    in-out property <float> progress;
    // 总时长 (秒)
    in-out property <float> duration;
    // 播放/暂停状态
    in-out property <bool> paused;
    // 是否正在拖动进度条
    in-out property <bool> dragging;
    // 歌曲列表
    in-out property <[SongInfo]> song_list;
    // 当前播放歌曲的信息
    in-out property <SongInfo> current_song;
    // 播放模式
    in-out property <PlayMode> play_mode;
    // 是否已被用户触发播放
    in-out property <bool> user_listening;
    // 当前播放歌曲的歌词
    in-out property <[LyricItem]> lyrics;
    // 当前歌词视窗的滚动条位置（一般为负数）
    in property <length> lyric_viewport_y;
    // 当前一行歌词的高度
    in-out property <length> lyric_line_height: 40px;
    // 歌曲文件夹配置
    in-out property <string> song_dir;
    // 关于信息
    in property <string> about_info;
    // 专辑封面图像
    in property <image> album_image;
    // 播放历史
    in property <[SongInfo]> play_history;
    // 播放历史索引
    in property <int> history_index: 0;
    // 歌曲排序方式
    in-out property <SortKey> sort_key;
    in-out property <SortKey> last_sort_key;
    // 升序/降序
    in-out property <bool> sort_ascending: true;
    // 当前语言
    in-out property <string> lang;
    // 主题颜色
    in-out property <bool> light_ui;
    // 音量大小
    in property <float> volume;
    // 频谱数据 (0..1)
    in-out property <[float]> spectrum;
    // 是否显示频谱条
    in-out property <bool> show_spectrum: true;
}

export component MainWindow inherits Window {
    default-font-family: "Microsoft YaHei UI";
    default-font-size: 14px;
    preferred-width: 850px;
    preferred-height: 500px;
    min-width: 850px;
    min-height: 500px;
    title: "Zeedle";
    icon: @image-url("cover.svg");
    forward-focus: key-input-handler;
    callback toggle_play();
    callback play(SongInfo, TriggerSource);
    callback play_next();
    callback play_prev();
    callback change_progress(float);
    callback switch_mode(PlayMode);
    callback refresh_song_list(string);
    callback sort_song_list(SortKey, bool);
    callback set_lang(string);
    callback change_volume(float);
    pure callback format_duration(float) -> string;
    in-out property <int> current_page: 0;
    in-out property <bool> sidebar_expanded: false;
    public function set_light_theme(yes: bool) {
        UIState.light_ui = yes;
        if (yes) {
            Palette.color-scheme = ColorScheme.light;
        } else {
            Palette.color-scheme = ColorScheme.dark;
        }
    }

    HorizontalLayout {
        height: 100%;
        spacing: 0px;

        sidebar := Sidebar {
            expanded <=> root.sidebar_expanded;
            current_page: root.current_page;
            change_page(p) => {
                root.current_page = p;
            }
            request_focus => {
                root.focus();
            }
        }

        content-pane := Rectangle {
            horizontal-stretch: 1;
            height: 100%;

            if root.current_page == 0: VerticalLayout {
                width: 100%;
                height: 100%;
                SongListView {
                    ascending <=> UIState.sort_ascending;
                    sort-key <=> UIState.sort_key;
                    last-sort-key <=> UIState.last_sort_key;
                    song-list <=> UIState.song_list;
                    current-song <=> UIState.current_song;
                    sort-songs(key, asc) => {
                        root.sort_song_list(key, asc);
                    }
                    play-song(info, src) => {
                        root.play(info, src);
                    }
                }

                ControlPanel {
                    max-height: 80px;
                    min-height: 50px;
                    preferred-height: 60px;
                    progress <=> UIState.progress;
                    duration <=> UIState.duration;
                    paused <=> UIState.paused;
                    dragging <=> UIState.dragging;
                    play_mode <=> UIState.play_mode;
                    current_song <=> UIState.current_song;
                    album_image <=> UIState.album_image;
                    volume <=> UIState.volume;
                    change-progress(p) => {
                        root.change_progress(p);
                        root.focus();
                    }
                    toggle-play() => {
                        root.toggle_play();
                    }
                    play-next() => {
                        root.play_next();
                    }
                    play-prev() => {
                        root.play_prev();
                    }
                    switch-mode(m) => {
                        root.switch_mode(m);
                    }
                    change-volume(v) => {
                        root.change_volume(v);
                        root.focus();
                    }
                    double-clicked() => {
                        root.current_page = 1;
                    }
                    format-duration(d) => {
                        return root.format_duration(d);
                    }
                }
            }

            if root.current_page == 1: Rectangle {
                width: 100%;
                height: 100%;
                z: -5;
                TouchArea {
                    double-clicked => {
                        root.current_page = 0;
                    }
                }

                LyricsPanel {
                    width: 100%;
                    height: 100%;
                    album_image <=> UIState.album_image;
                    current_song <=> UIState.current_song;
                    lyrics <=> UIState.lyrics;
                    progress <=> UIState.progress;
                    lyric_viewport_y <=> UIState.lyric_viewport_y;
                }
            }

            if root.current_page == 2: Rectangle {
                width: 100%;
                height: 100%;
                TouchArea {
                    clicked => {
                        root.focus();
                    }
                }

                SettingsPanel {
                    width: 100%;
                    height: 100%;
                    song_dir <=> UIState.song_dir;
                    lang <=> UIState.lang;
                    light_ui <=> UIState.light_ui;
                    show_spectrum <=> UIState.show_spectrum;
                    refresh_song_list(p) => {
                        root.refresh_song_list(p);
                    }
                    set_lang(l) => {
                        root.set_lang(l);
                    }
                    set_light_theme(yes) => {
                        root.set_light_theme(yes);
                    }
                }
            }

            if root.current_page == 3: Text {
                width: 100%;
                height: 100%;
                // font-size: 16px;
                text: UIState.about_info;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    spectrum-bg := Rectangle {
        x: root.sidebar_expanded ? 210px : 60px;
        width: root.width - self.x;
        height: root.height;
        z: -5;
        visible: UIState.show_spectrum;
        SpectrumView {
            width: parent.width;
            height: 60px;
            y: parent.height - self.height;
            bins: UIState.spectrum;
        }
    }

    key-input-handler := FocusScope {
        focus-on-click: false;
        key-released(event) => {
            if event.text == Key.Space {
                root.toggle_play();
                return accept;
            } else if event.text == Key.RightArrow || event.text == Key.DownArrow {
                root.play_next();
                return accept;
            } else if event.text == Key.LeftArrow || event.text == Key.UpArrow {
                root.play_prev();
                return accept;
            } else if event.text == Key.F1 {
                root.current_page = 0;
                return accept;
            } else if event.text == Key.F2 {
                root.current_page = 1;
                return accept;
            } else if event.text == Key.F3 {
                root.current_page = 2;
                return accept;
            } else if event.text == Key.F4 {
                root.current_page = 3;
                return accept;
            }
            return reject;
        }
    }
}
