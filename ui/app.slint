import { Theme } from "theme.slint";
import { Palette } from "std-widgets.slint";
import { ControlPanel } from "control_panel.slint";
import { Sidebar } from "sidebar.slint";
import { SpectrumView } from "spectrum.slint";
import { LyricsPanel } from "lyrics_panel.slint";
import { SongItem, SongListView } from "song_list.slint";
import { TitleBar } from "title_bar.slint";
import { SettingsPanel } from "settings_panel.slint";
import { SearchPanel } from "search_panel.slint";
import {
    PlayMode,
    LyricItem,
    SongInfo,
    SortKey,
    TriggerSource,
} from "types.slint";

export {
    PlayMode,
    LyricItem,
    SongInfo,
    SortKey,
    TriggerSource,
}

// === Group 1: Audio playback engine state ===
export global PlaybackGlobal {
    in-out property <float> progress;
    in-out property <float> duration;
    in-out property <bool> paused;
    in-out property <bool> dragging;
    in-out property <PlayMode> play_mode;
    in property <bool> user_listening;
    in-out property <float> volume;
    in-out property <[float]> spectrum;
    in-out property <bool> show_spectrum: true;
}

// === Group 2: All display & settings state ===
export global DisplayGlobal {
    in-out property <SongInfo> current_song;
    in-out property <[LyricItem]> lyrics;
    in property <length> lyric_viewport_y;
    in-out property <length> lyric_line_height: 40px;
    in property <image> album_image;
    in property <[SongInfo]> play_history;
    in property <int> history_index: 0;
    in-out property <string> song_dir;
    in property <styled-text> about_info;
    in-out property <SortKey> sort_key;
    in-out property <SortKey> last_sort_key;
    in-out property <bool> sort_ascending: true;
    in-out property <string> lang;
    in-out property <bool> light_ui;
    in-out property <bool> follow_system_theme;
    in-out property <[SongInfo]> song_list;
    in-out property <[SongInfo]> search_results;
    in-out property <string> search_query;
    in-out property <string> app-font-family;
}

export component MainWindow inherits Window {
    default-font-family <=> DisplayGlobal.app-font-family;
    default-font-size: 14px;
    preferred-width: 850px;
    preferred-height: 500px;
    min-width: 850px;
    min-height: 500px;
    title: "Zeedle";
    icon: @image-url("cover.svg");
    no-frame: true;
    resize-border-width: 5px;
    background: transparent;
    forward-focus: content-pane;
    callback toggle_play();
    callback play(SongInfo, TriggerSource);
    callback play_next();
    callback play_prev();
    callback change_progress(float);
    callback switch_mode(PlayMode);
    callback refresh_song_list(string);
    callback sort_song_list(SortKey, bool);
    callback set_lang(string);
    callback change_volume(float);
    callback set_show_spectrum(bool);
    callback set_follow_system_theme(bool);
    callback select_song_dir();
    callback search_songs(string);
    pure callback format_duration(float) -> string;
    callback window_minimize();
    callback window_maximize();
    callback window_close();
    callback window_drag_delta(float, float);
    pure callback open_url_in_browser(string);
    in-out property <int> current_page: 0;
    in-out property <bool> sidebar_expanded: false;
    public function set_light_theme(yes: bool) {
        DisplayGlobal.light_ui = yes;
        Theme.is-dark = !yes;
        if (yes) {
            Palette.color-scheme = ColorScheme.light;
        } else {
            Palette.color-scheme = ColorScheme.dark;
        }
    }

    window-frame := Rectangle {
        width: 100%;
        height: 100%;
        border-radius: root.maximized ? 0px : 6px;
        border-width: root.maximized ? 0px : 1px;
        border-color: Theme.border;
        background: Theme.panel;
        clip: true;

        title-bar := TitleBar {
            y: 0;
            width: 100%;
            is_light_theme <=> DisplayGlobal.light_ui;
            theme_toggle_enabled: !DisplayGlobal.follow_system_theme;
            close => { root.window_close(); }
            minimize => { root.window_minimize(); }
            maximize => { root.window_maximize(); }
            toggle_theme => {
                DisplayGlobal.follow_system_theme = false;
                root.set_light_theme(!DisplayGlobal.light_ui);
            }
            drag_delta(dx, dy) => {
                root.window_drag_delta(dx, dy);
            }
        }

        HorizontalLayout {
            y: title-bar.height;
            height: root.height - title-bar.height;
            spacing: 0px;

            sidebar := Sidebar {
                expanded <=> root.sidebar_expanded;
                current_page: root.current_page;
                change_page(p) => {
                    root.current_page = p;
                }
                request_focus => {
                    root.focus();
                }
            }

            content-pane := FocusScope {
                horizontal-stretch: 1;
                height: 100%;

                content-rect := Rectangle {
                    width: 100%;
                    height: 100%;
                    border-top-left-radius: 10px;
                    clip: true;

                    spectrum-bg := Rectangle {
                        width: 100%;
                        height: 100%;
                        z: 5;
                        visible: PlaybackGlobal.show_spectrum;
                        SpectrumView {
                            width: parent.width;
                            height: 60px;
                            y: parent.height - self.height;
                            bins: PlaybackGlobal.spectrum;
                        }
                    }

                    if root.current_page == 0: VerticalLayout {
                        width: 100%;
                        height: 100%;
                        SongListView {
                            ascending <=> DisplayGlobal.sort_ascending;
                            sort-key <=> DisplayGlobal.sort_key;
                            last-sort-key <=> DisplayGlobal.last_sort_key;
                            song-list <=> DisplayGlobal.song_list;
                            current-song <=> DisplayGlobal.current_song;
                            sort-songs(key, asc) => {
                                root.sort_song_list(key, asc);
                            }
                            play-song(info, src) => {
                                root.play(info, src);
                            }
                        }

                        ControlPanel {
                            max-height: 80px;
                            min-height: 50px;
                            preferred-height: 60px;
                            progress <=> PlaybackGlobal.progress;
                            duration <=> PlaybackGlobal.duration;
                            paused <=> PlaybackGlobal.paused;
                            dragging <=> PlaybackGlobal.dragging;
                            play_mode <=> PlaybackGlobal.play_mode;
                            current_song <=> DisplayGlobal.current_song;
                            album_image <=> DisplayGlobal.album_image;
                            volume <=> PlaybackGlobal.volume;
                            change-progress(p) => {
                                root.change_progress(p);
                                root.focus();
                            }
                            toggle-play() => {
                                root.toggle_play();
                            }
                            play-next() => {
                                root.play_next();
                            }
                            play-prev() => {
                                root.play_prev();
                            }
                            switch-mode(m) => {
                                root.switch_mode(m);
                            }
                            change-volume(v) => {
                                root.change_volume(v);
                                root.focus();
                            }
                            double-clicked() => {
                                root.current_page = 2;
                            }
                            format-duration(d) => {
                                return root.format_duration(d);
                            }
                        }
                    }

                    if root.current_page == 1: SearchPanel {
                        width: 100%;
                        height: 100%;
                        search-query <=> DisplayGlobal.search_query;
                        all-songs <=> DisplayGlobal.song_list;
                        search-results <=> DisplayGlobal.search_results;
                        current-song <=> DisplayGlobal.current_song;
                        search(query) => {
                            root.search_songs(query);
                        }
                        play-song(info, src) => {
                            root.play(info, src);
                        }
                    }

                    if root.current_page == 2: Rectangle {
                        width: 100%;
                        height: 100%;
                        z: -5;
                        TouchArea {
                            double-clicked => {
                                root.current_page = 0;
                            }
                        }

                        LyricsPanel {
                            width: 100%;
                            height: 100%;
                            album_image <=> DisplayGlobal.album_image;
                            current_song <=> DisplayGlobal.current_song;
                            lyrics <=> DisplayGlobal.lyrics;
                            progress <=> PlaybackGlobal.progress;
                            lyric_viewport_y <=> DisplayGlobal.lyric_viewport_y;
                        }
                    }

                    if root.current_page == 3: Rectangle {
                        width: 100%;
                        height: 100%;
                        background: Theme.surface;
                        TouchArea {
                            clicked => {
                                root.focus();
                            }
                        }

                        SettingsPanel {
                            width: 100%;
                            height: 100%;
                            song_dir <=> DisplayGlobal.song_dir;
                            lang <=> DisplayGlobal.lang;
                            follow_system_theme <=> DisplayGlobal.follow_system_theme;
                            show_spectrum <=> PlaybackGlobal.show_spectrum;
                            refresh_song_list(p) => {
                                root.refresh_song_list(p);
                            }
                            set_lang(l) => {
                                root.set_lang(l);
                            }
                            set_follow_system_theme(yes) => {
                                root.set_follow_system_theme(yes);
                            }
                            set_show_spectrum(yes) => {
                                root.set_show_spectrum(yes);
                            }
                            select_song_dir => {
                                root.select_song_dir();
                            }
                        }
                    }

                    if root.current_page == 4: Rectangle {
                        width: 100%;
                        height: 100%;
                        background: Theme.surface;

                        VerticalLayout {
                            width: 100%;
                            height: 100%;
                            alignment: center;
                            spacing: 10px;
                            HorizontalLayout {
                                alignment: center;
                                Image {
                                    source: @image-url("cover.svg");
                                    width: 120px;
                                    height: 120px;
                                }
                            }

                            StyledText {
                                text: DisplayGlobal.about_info;
                                link-color: Theme.accent;
                                horizontal-alignment: center;
                                link-clicked(link) => { open_url_in_browser(link) }
                            }
                        }
                    }
                }

                key-released(event) => {
                    if event.text == Key.Space {
                        root.toggle_play();
                    } else if event.text == Key.RightArrow || event.text == Key.DownArrow {
                        root.play_next();
                    } else if event.text == Key.LeftArrow || event.text == Key.UpArrow {
                        root.play_prev();
                    } else if event.text == Key.F1 {
                        root.current_page = 0;
                    } else if event.text == Key.F2 {
                        root.current_page = 1;
                    } else if event.text == Key.F3 {
                        root.current_page = 2;
                    } else if event.text == Key.F4 {
                        root.current_page = 3;
                    } else if event.text == Key.F5 {
                        root.current_page = 4;
                    } else {
                        return reject;
                    }
                    // Re-establish focus on this FocusScope after structural
                    // page changes that may have invalidated the focus state.
                    root.focus();
                    return accept;
                }
            }
        }
    }
}
