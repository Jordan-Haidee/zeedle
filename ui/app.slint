import {
    ListView,
    ComboBox,
    Slider,
    LineEdit,
    Switch,
    Palette,
} from "std-widgets.slint";
import {
    NextSongButton,
    PrevSongButton,
    PlayPauseButton,
    OverlapButton,
    RandomButton,
    PlayMode,
    MusicVolumeButton,
} from "button.slint";
import { SongInfo, TitleBar, SongItem, SortKey } from "song.slint";
import { LyricLine } from "lyric.slint";
import "msyhl.ttc";


// lyric item
export struct LyricItem {
    time: float,
    duration: float,
    text: string,
}

// trigger source
export enum TriggerSource {
    ClickItem,
    Prev,
    Next,
}

// ui state
export global UIState {
    // 当前播放进度 (秒)
    in-out property <float> progress;
    // 总时长 (秒)
    in-out property <float> duration;
    // 播放/暂停状态
    in-out property <bool> paused;
    // 是否正在拖动进度条
    in-out property <bool> dragging;
    // 歌曲列表
    in-out property <[SongInfo]> song_list;
    // 当前播放歌曲的信息
    in-out property <SongInfo> current_song;
    // 播放模式
    in-out property <PlayMode> play_mode;
    // 是否已被用户触发播放
    in-out property <bool> user_listening;
    // 当前播放歌曲的歌词
    in-out property <[LyricItem]> lyrics;
    // 当前歌词视窗的滚动条位置（一般为负数）
    in property <length> lyric_viewport_y;
    // 当前一行歌词的高度
    in-out property <length> lyric_line_height: 40px;
    // 歌曲文件夹配置
    in-out property <string> song_dir;
    // 关于信息
    in property <string> about_info;
    // 专辑封面图像
    in property <image> album_image;
    // 播放历史
    in property <[SongInfo]> play_history;
    // 播放历史索引
    in property <int> history_index: 0;
    // 歌曲排序方式
    in-out property <SortKey> sort_key;
    in-out property <SortKey> last_sort_key;
    // 升序/降序
    in-out property <bool> sort_ascending: true;
    // 当前语言
    in-out property <string> lang;
    // 主题颜色
    in-out property <bool> light_ui;
    // 音量大小
    in property <float> volume;
    // 频谱数据 (0..1)
    in-out property <[float]> spectrum;
    // 是否显示频谱条
    in-out property <bool> show_spectrum: true;
}

component SpectrumView inherits Rectangle {
    in property <[float]> bins;
    in property <color> bar-color: Palette.foreground;
    height: 60px;
    width: 200px;
    clip: true;
    HorizontalLayout {
        width: 100%;
        height: 100%;
        alignment: center;
        spacing: 0px;
        for v in bins: Rectangle {
            width: parent.width / (root.bins.length * 2);
            height: parent.height * v;
            y: parent.height - self.height;
            border-radius: 1px;
            opacity: 0.3;
            background: root.bar-color;
        }
    }
}

component SongListView inherits Rectangle {
    in-out property <bool> ascending;
    in-out property <SortKey> sort-key;
    in-out property <SortKey> last-sort-key;
    in-out property <[SongInfo]> song-list;
    in property <SongInfo> current-song;
    callback sort-songs(SortKey, bool);
    callback play-song(SongInfo, TriggerSource);
    VerticalLayout {
        width: 100%;
        height: 100%;
        TitleBar {
            ascending: root.ascending;
            key: root.sort-key;
            sort-items(key, ascending) => {
                if (root.last-sort-key == key) {
                    root.sort-songs(key, !ascending);
                } else {
                    root.sort-songs(key, true)
                }
            }
        }

        ListView {
            for item in root.song-list: SongItem {
                info: item;
                playing: item.song-path == root.current-song.song-path;
                double_clicked => {
                    root.play-song(item, TriggerSource.ClickItem);
                }
            }
        }
    }
}

component SidebarNavItem inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <bool> selected;
    in property <bool> expanded;
    callback clicked();
    height: 38px;
    border-radius: 8px;
    clip: true;
    background: touch.pressed ? Palette.control-background.darker(0.15) : (selected ? Palette.control-background.darker(0.1) : (touch.has-hover ? Palette.control-background : transparent));

    Rectangle {
        visible: selected;
        width: 3px;
        height: 16px;
        x: 3px;
        y: (parent.height - self.height) / 2;
        border-radius: 1.5px;
        background: Palette.accent-background;
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 14px;
        padding-right: 10px;
        spacing: expanded ? 10px : 0px;
        animate spacing {
            duration: 180ms;
            easing: ease-out-quad;
        }

        Rectangle {
            width: 20px;
            Text {
                width: 100%;
                text: root.icon;
                // font-size: 16px;
                font-weight: root.selected ? 600 : 400;
                color: root.selected ? Palette.accent-background : Palette.foreground.darker(0.2);
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            clip: true;
            width: expanded ? nav-label.preferred-width : 0px;
            visible: expanded || self.width > 0px;
            animate width {
                duration: 180ms;
                easing: ease-out-quad;
            }
            nav-label := Text {
                width: 100%;
                text: root.label;
                // font-size: 13px;
                font-weight: root.selected ? 600 : 400;
                color: root.selected ? Palette.foreground : Palette.foreground.darker(0.2);
                vertical-alignment: center;
                overflow: TextOverflow.elide;
                opacity: expanded ? 1 : 0;
                animate opacity { duration: 120ms; }
            }
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component ControlPanel inherits Rectangle {
    in-out property <float> progress;
    in property <float> duration;
    in property <bool> paused;
    in property <PlayMode> play_mode;
    in-out property <bool> dragging;
    in property <SongInfo> current_song;
    in property <image> album_image;
    callback change-progress(float);
    callback toggle-play();
    callback play-next();
    callback play-prev();
    callback switch-mode(PlayMode);
    callback change-volume(float);
    callback double-clicked();
    pure callback format-duration(float) -> string;
    VerticalLayout {
        width: 100%;
        height: 100%;
        Slider {
            minimum: 0;
            maximum: root.duration;
            // 单向绑定被用户强制改变状态后，绑定失效，不再自动更新, 所以双向绑定
            value <=> root.progress;
            released(v) => {
                root.dragging = false;
                change_progress(v);
            }
            changed(_) => {
                root.dragging = true;
            }
        }

        HorizontalLayout {
            height: 80%;
            alignment: center;
            TouchArea {
                width: 35%;
                height: 100%;
                double-clicked => {
                    root.double-clicked()
                };
                HorizontalLayout {
                    alignment: start;
                    spacing: 3px;
                    Rectangle {
                        width: 20%;
                        height: 100%;
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            border-radius: 4px;
                            clip: true;
                            drop-shadow-blur: 6px;
                            Image {
                                y: parent.height / 2 - self.height / 2;
                                width: 100%;
                                height: 100%;
                                source: root.album_image;
                                image-fit: contain;
                            }
                        }
                    }

                    Rectangle {
                        width: 80%;
                        height: 100%;
                        Text {
                            width: 100%;
                            x: parent.width / 2 - self.width / 2;
                            text: root.current_song.song_name + " - " + root.current_song.singer;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            overflow: TextOverflow.elide;
                        }
                    }
                }
            }

            Rectangle {
                width: 6%;
                OverlapButton {
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    width: 20px;
                    height: 20px;
                    mode: root.play_mode;
                    clicked => {
                        if (root.play_mode == PlayMode.InOrder) {
                            root.switch_mode(PlayMode.Recursive);
                        } else {
                            root.switch_mode(PlayMode.InOrder);
                        }
                    }
                }
            }

            Rectangle {
                width: 6%;
                PrevSongButton {
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    width: 20px;
                    height: 20px;
                    clicked => {
                        root.play_prev();
                    }
                }
            }

            Rectangle {
                width: 6%;
                PlayPauseButton {
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    width: 20px;
                    height: 20px;
                    // 单向绑定被用户强制改变状态后，绑定失效，不再自动更新, 所以双向绑定
                    paused: root.paused;
                    toggled => {
                        root.toggle_play();
                    }
                }
            }

            Rectangle {
                width: 6%;
                NextSongButton {
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    width: 20px;
                    height: 20px;
                    clicked => {
                        root.play_next();
                    }
                }
            }

            Rectangle {
                width: 6%;
                border-color: transparent;
                RandomButton {
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    selected: root.play_mode == PlayMode.Random;
                    width: 20px;
                    height: 20px;
                    clicked => {
                        root.switch_mode(PlayMode.Random);
                    }
                }
            }

            Rectangle {
                width: 25%;
                TouchArea {
                    double-clicked => {
                        root.double-clicked()
                    }
                }

                Text {
                    x: parent.width / 2 - self.width / 2;
                    text: root.format-duration(root.progress) + " / " + root.format-duration(root.duration);
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }

            Rectangle {
                width: 10%;
                MusicVolumeButton {
                    icon-height: 20px;
                    slider-height: 55px;
                    volume <=> UIState.volume;
                    change-volume(v) => {
                        root.change-volume(v)
                    }
                }
            }
        }
    }
}

component LyricsPanel inherits Rectangle {
    in property <image> album_image;
    in property <SongInfo> current_song;
    in property <[LyricItem]> lyrics;
    in property <float> progress;
    in-out property <length> lyric_viewport_y;
    HorizontalLayout {
        width: 100%;
        height: 100%;
        VerticalLayout {
            width: 30%;
            alignment: center;
            lyric-image := Rectangle {
                x: parent.width / 2 - self.width / 2;
                width: 180px;
                height: self.width;
                clip: true;
                border-radius: 8px;
                drop-shadow-blur: 8px;
                Image {
                    width: 100%;
                    height: 100%;
                    source: album_image;
                }
            }

            Text {
                width: 100%;
                height: 25px;
                // font-size: 13px;
                x: lyric-image.x;
                vertical-alignment: bottom;
                text: @tr("Artist: {}", current_song.singer);
                overflow: elide;
            }

            Text {
                width: 100%;
                height: 25px;
                // font-size: 13px;
                x: lyric-image.x;
                vertical-alignment: bottom;
                text: @tr("Title: {}", current_song.song_name);
                overflow: elide;
            }
        }

        VerticalLayout {
            width: 70%;
            alignment: center;
            ListView {
                height: 100%;
                width: 100%;
                mouse-drag-pan-enabled: false;
                viewport-y <=> lyric_viewport_y;
                for item in lyrics: LyricLine {
                    content: item.text;
                    playing: (progress >= item.time) && (progress < item.time + item.duration);
                }
            }
        }
    }
}

component SettingsPanel inherits Rectangle {
    in-out property <string> song_dir;
    in-out property <string> lang;
    in-out property <bool> light_ui;
    in-out property <bool> show_spectrum;
    callback refresh_song_list(string);
    callback set_lang(string);
    callback set_light_theme(bool);
    VerticalLayout {
        width: 100%;
        height: 100%;
        alignment: center;
        spacing: 20px;
        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            Rectangle {
                height: 30px;
                width: 200px;
                Text {
                    x: parent.width - self.width;
                    vertical-alignment: center;
                    text: @tr("Music directory: ");
                }
            }

            LineEdit {
                width: 200px;
                text <=> song_dir;
                accepted(p) => {
                    refresh_song_list(p);
                }
            }
        }

        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            Rectangle {
                height: 30px;
                width: 200px;
                Text {
                    x: parent.width - self.width;
                    vertical-alignment: center;
                    text: @tr("Language: ");
                }
            }

            ComboBox {
                width: 200px;
                current-value <=> lang;
                model: ["", "zh_CN", "es", "fr", "de", "ru"];
                selected(current-value) => {
                    root.set_lang(current-value);
                }
            }
        }

        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            Rectangle {
                height: 30px;
                width: 200px;
                Text {
                    x: parent.width - self.width;
                    vertical-alignment: center;
                    text: @tr("Light theme: ");
                }
            }

            Switch {
                width: 200px;
                checked <=> light_ui;
                text: self.checked ? @tr("On") : @tr("Off");
                toggled => {
                    root.set_light_theme(self.checked);
                }
            }
        }

        HorizontalLayout {
            alignment: center;
            spacing: 10px;
            Rectangle {
                height: 30px;
                width: 200px;
                Text {
                    x: parent.width - self.width;
                    vertical-alignment: center;
                    text: @tr("Spectrum display: ");
                }
            }

            Switch {
                width: 200px;
                checked <=> show_spectrum;
                text: self.checked ? @tr("On") : @tr("Off");
            }
        }
    }
}

export component MainWindow inherits Window {
    // Use locale-specific family names so Windows can resolve YaHei after runtime language switches.
    private property <string> app_font_family: UIState.lang == "" ? "Microsoft YaHei UI Light" : "Microsoft YaHei UI";
    default-font-family: app_font_family;
    default-font-size: 14px;
    preferred-width: 850px;
    preferred-height: 500px;
    min-width: 850px;
    min-height: 500px;
    title: "Zeedle";
    icon: @image-url("cover.svg");
    forward-focus: key-input-handler;
    callback toggle_play();
    callback play(SongInfo, TriggerSource);
    callback play_next();
    callback play_prev();
    callback change_progress(float);
    callback switch_mode(PlayMode);
    callback refresh_song_list(string);
    callback sort_song_list(SortKey, bool);
    callback set_lang(string);
    callback change_volume(float);
    pure callback format_duration(float) -> string;
    in-out property <int> current_page: 0;
    in-out property <bool> sidebar_expanded: false;
    public function set_light_theme(yes: bool) {
        UIState.light_ui = yes;
        if (yes) {
            Palette.color-scheme = ColorScheme.light;
        } else {
            Palette.color-scheme = ColorScheme.dark;
        }
    }

    HorizontalLayout {
        height: 100%;
        spacing: 0px;

        sidebar := Rectangle {
            width: root.sidebar_expanded ? 210px : 60px;
            height: 100%;
            background: Palette.control-background;
            animate width {
                duration: 200ms;
                easing: ease-out-quad;
            }

            VerticalLayout {
                width: 100%;
                height: 100%;
                padding-left: 6px;
                padding-right: 6px;
                padding-top: 10px;
                padding-bottom: 10px;
                spacing: 6px;

                Rectangle {
                    height: 36px;
                    border-radius: 8px;
                    background: toggle-touch.has-hover ? Palette.background : transparent;
                    HorizontalLayout {
                        width: 100%;
                        height: 100%;
                        padding-left: 14px;
                        padding-right: 10px;
                        spacing: root.sidebar_expanded ? 10px : 0px;
                        animate spacing {
                            duration: 180ms;
                            easing: ease-out-quad;
                        }
                        Text {
                            width: 20px;
                            text: "☰";
                            // font-size: 16px;
                            color: Palette.foreground.darker(0.2);
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            clip: true;
                            width: root.sidebar_expanded ? title-label.preferred-width : 0px;
                            visible: root.sidebar_expanded || self.width > 0px;
                            animate width {
                                duration: 180ms;
                                easing: ease-out-quad;
                            }
                            title-label := Text {
                                text: "Zeedle";
                                // font-size: 13px;
                                font-weight: 600;
                                color: Palette.foreground;
                                vertical-alignment: center;
                                opacity: root.sidebar_expanded ? 1 : 0;
                                animate opacity { duration: 120ms; }
                            }
                        }
                    }

                    toggle-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.sidebar_expanded = !root.sidebar_expanded;
                            root.focus();
                        }
                    }
                }

                Rectangle {
                    height: 4px;
                }

                SidebarNavItem {
                    icon: "▤";
                    label: @tr("Gallery");
                    selected: root.current_page == 0;
                    expanded: root.sidebar_expanded;
                    clicked => {
                        root.current_page = 0;
                        root.focus();
                    }
                }

                SidebarNavItem {
                    icon: "♪";
                    label: @tr("Lyrics");
                    selected: root.current_page == 1;
                    expanded: root.sidebar_expanded;
                    clicked => {
                        root.current_page = 1;
                        root.focus();
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                Rectangle {
                    height: 1px;
                    background: Palette.background.darker(0.2);
                }

                SidebarNavItem {
                    icon: "⚙";
                    label: @tr("Settings");
                    selected: root.current_page == 2;
                    expanded: root.sidebar_expanded;
                    clicked => {
                        root.current_page = 2;
                        root.focus();
                    }
                }

                SidebarNavItem {
                    icon: "i";
                    label: @tr("About");
                    selected: root.current_page == 3;
                    expanded: root.sidebar_expanded;
                    clicked => {
                        root.current_page = 3;
                        root.focus();
                    }
                }
            }

            Rectangle {
                x: parent.width - 1px;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: Palette.background.darker(0.2);
            }
        }

        content-pane := Rectangle {
            horizontal-stretch: 1;
            height: 100%;

            if root.current_page == 0: VerticalLayout {
                width: 100%;
                height: 100%;
                SongListView {
                    ascending <=> UIState.sort_ascending;
                    sort-key <=> UIState.sort_key;
                    last-sort-key <=> UIState.last_sort_key;
                    song-list <=> UIState.song_list;
                    current-song <=> UIState.current_song;
                    sort-songs(key, asc) => {
                        root.sort_song_list(key, asc);
                    }
                    play-song(info, src) => {
                        root.play(info, src);
                    }
                }

                ControlPanel {
                    max-height: 80px;
                    min-height: 50px;
                    preferred-height: 60px;
                    progress <=> UIState.progress;
                    duration <=> UIState.duration;
                    paused <=> UIState.paused;
                    dragging <=> UIState.dragging;
                    play_mode <=> UIState.play_mode;
                    current_song <=> UIState.current_song;
                    album_image <=> UIState.album_image;
                    change-progress(p) => {
                        root.change_progress(p);
                        root.focus();
                    }
                    toggle-play() => {
                        root.toggle_play();
                    }
                    play-next() => {
                        root.play_next();
                    }
                    play-prev() => {
                        root.play_prev();
                    }
                    switch-mode(m) => {
                        root.switch_mode(m);
                    }
                    change-volume(v) => {
                        root.change_volume(v);
                        root.focus();
                    }
                    double-clicked() => {
                        root.current_page = 1;
                    }
                    format-duration(d) => {
                        return root.format_duration(d);
                    }
                }
            }

            if root.current_page == 1: Rectangle {
                width: 100%;
                height: 100%;
                z: -5;
                TouchArea {
                    double-clicked => {
                        root.current_page = 0;
                    }
                }

                LyricsPanel {
                    width: 100%;
                    height: 100%;
                    album_image <=> UIState.album_image;
                    current_song <=> UIState.current_song;
                    lyrics <=> UIState.lyrics;
                    progress <=> UIState.progress;
                    lyric_viewport_y <=> UIState.lyric_viewport_y;
                }
            }

            if root.current_page == 2: Rectangle {
                width: 100%;
                height: 100%;
                TouchArea {
                    clicked => {
                        root.focus();
                    }
                }

                SettingsPanel {
                    width: 100%;
                    height: 100%;
                    song_dir <=> UIState.song_dir;
                    lang <=> UIState.lang;
                    light_ui <=> UIState.light_ui;
                    show_spectrum <=> UIState.show_spectrum;
                    refresh_song_list(p) => {
                        root.refresh_song_list(p);
                    }
                    set_lang(l) => {
                        root.set_lang(l);
                    }
                    set_light_theme(yes) => {
                        root.set_light_theme(yes);
                    }
                }
            }

            if root.current_page == 3: Text {
                width: 100%;
                height: 100%;
                // font-size: 16px;
                text: UIState.about_info;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    spectrum-bg := Rectangle {
        x: root.sidebar_expanded ? 210px : 60px;
        width: root.width - self.x;
        height: root.height;
        z: -5;
        visible: UIState.show_spectrum;
        SpectrumView {
            width: parent.width;
            height: 60px;
            y: parent.height - self.height;
            bins: UIState.spectrum;
        }
    }

    key-input-handler := FocusScope {
        focus-on-click: false;
        key-released(event) => {
            if event.text == Key.Space {
                root.toggle_play();
                return accept;
            } else if event.text == Key.RightArrow || event.text == Key.DownArrow {
                root.play_next();
                return accept;
            } else if event.text == Key.LeftArrow || event.text == Key.UpArrow {
                root.play_prev();
                return accept;
            } else if event.text == Key.F1 {
                root.current_page = 0;
                return accept;
            } else if event.text == Key.F2 {
                root.current_page = 1;
                return accept;
            } else if event.text == Key.F3 {
                root.current_page = 2;
                return accept;
            } else if event.text == Key.F4 {
                root.current_page = 3;
                return accept;
            }
            return reject;
        }
    }
}
