import { Theme } from "theme.slint";
import { Slider } from "std-widgets.slint";
import { SongInfo, PlayMode } from "types.slint";

export component SkipButton inherits Rectangle {
    callback clicked();
    in property <bool> forward: true;
    border-radius: self.width / 2;
    clip: true;
    border-width: 1px;
    property <bool> hovered: touch.has-hover;
    property <bool> pressed: touch.pressed;
    property <color> icon-color: pressed ? Theme.accent : (hovered ? Theme.text : Theme.text-secondary);
    background: pressed ? Theme.press : (hovered ? Theme.hover : Theme.surface);
    border-color: hovered ? Theme.text : Theme.border;
    drop-shadow-blur: hovered ? 8px : 4px;
    animate background {
        duration: 120ms;
        easing: ease-out-quad;
    }
    animate border-color {
        duration: 120ms;
        easing: ease-out-quad;
    }
    animate drop-shadow-blur {
        duration: 120ms;
        easing: ease-out-quad;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        width: 100%;
        height: 100%;
        clicked => {
            root.clicked();
        }
    }

    Path {
        x: parent.width * 0.12;
        y: parent.height * 0.12;
        width: parent.width * 0.76;
        height: parent.height * 0.76;
        viewbox-width: 24;
        viewbox-height: 24;
        fill: transparent;
        commands: root.forward ? "M6.029 4.285A2 2 0 0 0 3 6v12a2 2 0 0 0 3.029 1.715l9.997-5.998a2 2 0 0 0 .003-3.432z" : "M17.971 4.285A2 2 0 0 1 21 6v12a2 2 0 0 1-3.029 1.715l-9.997-5.998a2 2 0 0 1-.003-3.432z";
        stroke: root.icon-color;
        stroke-width: 2.3px;
        stroke-line-cap: round;
    }

    Path {
        x: parent.width * 0.12;
        y: parent.height * 0.12;
        width: parent.width * 0.76;
        height: parent.height * 0.76;
        viewbox-width: 24;
        viewbox-height: 24;
        fill: transparent;
        commands: root.forward ? "M21 4v16" : "M3 20V4";
        stroke: root.icon-color;
        stroke-width: 2.3px;
        stroke-line-cap: round;
    }
}

export component PlayPauseButton inherits Rectangle {
    in-out property <bool> paused:true;
    callback toggled();
    border-radius: self.width / 2;
    clip: true;
    border-width: 1px;
    property <bool> hovered: touch.has-hover;
    property <bool> pressed: touch.pressed;
    property <bool> active: !root.paused;
    property <color> icon-color: active ? Theme.accent : (pressed ? Theme.accent : (hovered ? Theme.text : Theme.text-secondary));
    background: pressed ? Theme.press : (hovered ? Theme.hover : Theme.surface);
    border-color: active ? Theme.accent : (hovered ? Theme.text : Theme.border);
    drop-shadow-blur: active ? 10px : (hovered ? 8px : 4px);
    animate background {
        duration: 120ms;
        easing: ease-out-quad;
    }
    animate border-color {
        duration: 120ms;
        easing: ease-out-quad;
    }
    animate drop-shadow-blur {
        duration: 120ms;
        easing: ease-out-quad;
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: pointer;
        clicked => {
            root.toggled();
        }
    }

    if !root.paused: Path {
        x: parent.width * 0.13;
        y: parent.height * 0.13;
        width: parent.width * 0.74;
        height: parent.height * 0.74;
        viewbox-width: 24;
        viewbox-height: 24;
        fill: transparent;
        commands: "M16 4h3a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z M5 4h3a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z";
        stroke: root.icon-color;
        stroke-width: 2.3px;
        stroke-line-cap: round;
    }

    if root.paused: Path {
        x: parent.width * 0.13;
        y: parent.height * 0.13;
        width: parent.width * 0.74;
        height: parent.height * 0.74;
        viewbox-width: 24;
        viewbox-height: 24;
        fill: transparent;
        commands: "M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z";
        stroke: root.icon-color;
        stroke-width: 2.3px;
        stroke-line-cap: round;
    }
}

export component PlayModeButton inherits Rectangle {
    in-out property <bool> selected;
    in-out property <bool> recursive: false;
    callback clicked();
    TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            root.clicked();
        }
    }

    Path {
        MoveTo {
            x: 90;
            y: 50;
        }

        ArcTo {
            x: 50;
            y: 10;
            radius-x: 40;
            radius-y: 40;
            x-rotation: 0;
            large-arc: true;
            sweep: true;
        }

        LineTo {
            x: 40;
            y: 4;
        }

        MoveTo {
            x: 50;
            y: 10;
        }

        LineTo {
            x: 42;
            y: 18;
        }

        stroke-width: 1px;
        stroke: selected ? Theme.accent : Theme.text;
    }

    if root.recursive: Path {
        MoveTo {
            x: 50;
            y: 40;
        }

        LineTo {
            x: 50;
            y: 60;
        }

        MoveTo {
            x: 50;
            y: 40;
        }

        LineTo {
            x: 44;
            y: 44;
        }

        stroke-width: 1px;
        stroke: selected ? Theme.accent : Theme.text;
    }
}


export component OverlapButton inherits Rectangle {
    in-out property <PlayMode> mode;
    callback clicked();
    PlayModeButton {
        width: 100%;
        height: 100%;
        recursive: mode == PlayMode.Recursive;
        selected: mode == PlayMode.Recursive || mode == PlayMode.InOrder;
        clicked => {
            root.clicked();
        }
    }
}

export component RandomButton inherits Rectangle {
    callback clicked();
    in-out property <bool> selected;
    TouchArea {
        clicked => {
            root.clicked();
        };
        Path {
            MoveTo {
                x: 0;
                y: 20;
            }

            LineTo {
                x: 30;
                y: 20;
            }

            LineTo {
                x: 70;
                y: 80;
            }

            LineTo {
                x: 100;
                y: 80;
            }

            LineTo {
                x: 90;
                y: 70;
            }

            MoveTo {
                x: 100;
                y: 80;
            }

            LineTo {
                x: 90;
                y: 90;
            }

            // 第二段
            MoveTo {
                x: 0;
                y: 80;
            }

            LineTo {
                x: 30;
                y: 80;
            }

            LineTo {
                x: 70;
                y: 20;
            }

            LineTo {
                x: 100;
                y: 20;
            }

            LineTo {
                x: 90;
                y: 30;
            }

            MoveTo {
                x: 100;
                y: 20;
            }

            LineTo {
                x: 90;
                y: 10;
            }

            stroke: selected ? Theme.accent : Theme.text;
            stroke-width: 1px;
        }
    }
}

export component MusicVolumeButton inherits Rectangle {
    in property <length> slider-height;
    in property <length> icon-height;
    in-out property <float> volume;
    property <bool> selected: icon.has-hover;
    callback change-volume(float);
    icon := TouchArea {
        if selected:
            Rectangle {
            z: 10;
            Slider {
                x: parent.width * 0.7;
                height: root.slider-height;
                minimum: 0;
                maximum: 1;
                value <=> root.volume;
                orientation: vertical;
                released(value) => {
                    root.change-volume(value);
                }
            }
        }
        Rectangle {
            height: root.icon-height;
            Path {
                MoveTo {
                    x: 0;
                    y: 50;
                }

                LineTo {
                    x: 0;
                    y: 25;
                }

                LineTo {
                    x: 25;
                    y: 25;
                }

                LineTo {
                    x: 50;
                    y: 0;
                }

                LineTo {
                    x: 50;
                    y: 100;
                }

                LineTo {
                    x: 25;
                    y: 75;
                }

                LineTo {
                    x: 0;
                    y: 75;
                }

                LineTo {
                    x: 0;
                    y: 25;
                }

                MoveTo {
                    x: 65;
                    y: 25;
                }

                ArcTo {
                    radius-x: 35;
                    radius-y: 35;
                    x: 65;
                    y: 75;
                    sweep: true;
                }

                MoveTo {
                    x: 80;
                    y: 0;
                }

                ArcTo {
                    radius-x: 70;
                    radius-y: 70;
                    x: 80;
                    y: 100;
                    sweep: true;
                }

                stroke: selected ? Theme.accent : Theme.text;
                stroke-width: 1px;
            }
        }
    }
}

export component ControlPanel inherits Rectangle {
    background: Theme.surface;

    in-out property <float> progress;
    in property <float> duration;
    in property <bool> paused;
    in property <PlayMode> play_mode;
    in-out property <bool> dragging;
    in property <SongInfo> current_song;
    in property <image> album_image;
    in-out property <float> volume;

    callback change-progress(float);
    callback toggle-play();
    callback play-next();
    callback play-prev();
    callback switch-mode(PlayMode);
    callback change-volume(float);
    callback double-clicked();
    pure callback format-duration(float) -> string;

    VerticalLayout {
        width: 100%;
        height: 100%;
        Slider {
            minimum: 0;
            maximum: root.duration;
            value <=> root.progress;
            released(v) => {
                root.dragging = false;
                change_progress(v);
            }
            changed(_) => {
                root.dragging = true;
            }
        }

        HorizontalLayout {
            height: 80%;
            alignment: center;
            TouchArea {
                width: 35%;
                height: 100%;
                double-clicked => {
                    root.double-clicked()
                };
                HorizontalLayout {
                    alignment: start;
                    spacing: 3px;
                    Rectangle {
                        width: 20%;
                        height: 100%;
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            border-radius: 4px;
                            clip: true;
                            drop-shadow-blur: 6px;
                            Image {
                                y: parent.height / 2 - self.height / 2;
                                width: 100%;
                                height: 100%;
                                source: root.album_image;
                                image-fit: contain;
                            }
                        }
                    }

                    Rectangle {
                        width: 80%;
                        height: 100%;
                        cur_song_text := Text {
                            width: 100%;
                            x: parent.width / 2 - self.width / 2;
                            text: root.current_song.song_name + " - " + root.current_song.singer;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                            overflow: TextOverflow.elide;
                            Tooltip {
                                text: @markdown("\{cur_song_text.text}");
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 6%;
                OverlapButton {
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    width: 20px;
                    height: 20px;
                    mode: root.play_mode;
                    clicked => {
                        if (root.play_mode == PlayMode.InOrder) {
                            root.switch_mode(PlayMode.Recursive);
                        } else {
                            root.switch_mode(PlayMode.InOrder);
                        }
                    }
                }
            }

            Rectangle {
                width: 6%;
                SkipButton {
                    forward: false;
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    width: 28px;
                    height: 28px;
                    clicked => {
                        root.play_prev();
                    }
                }
            }

            Rectangle {
                width: 6%;
                PlayPauseButton {
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    width: 28px;
                    height: 28px;
                    paused: root.paused;
                    toggled => {
                        root.toggle_play();
                    }
                }
            }

            Rectangle {
                width: 6%;
                SkipButton {
                    forward: true;
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    width: 28px;
                    height: 28px;
                    clicked => {
                        root.play_next();
                    }
                }
            }

            Rectangle {
                width: 6%;
                border-color: transparent;
                RandomButton {
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    selected: root.play_mode == PlayMode.Random;
                    width: 20px;
                    height: 20px;
                    clicked => {
                        root.switch_mode(PlayMode.Random);
                    }
                }
            }

            Rectangle {
                width: 25%;
                TouchArea {
                    double-clicked => {
                        root.double-clicked()
                    }
                }

                Text {
                    x: parent.width / 2 - self.width / 2;
                    text: root.format-duration(root.progress) + " / " + root.format-duration(root.duration);
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }

            Rectangle {
                width: 10%;
                MusicVolumeButton {
                    icon-height: 20px;
                    slider-height: 55px;
                    volume <=> root.volume;
                    change-volume(v) => {
                        root.change-volume(v)
                    }
                }
            }
        }
    }
}
