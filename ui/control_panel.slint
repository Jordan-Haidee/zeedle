import { Palette, Slider } from "std-widgets.slint";
import { SongInfo } from "song_list_view.slint";

@rust-attr(derive(serde::Serialize, serde::Deserialize))
export enum PlayMode { 
    InOrder, 
    Recursive, 
    Random
}

export component NextSongButton inherits Rectangle {
    callback clicked();
    border-radius: self.width / 2;
    clip: true;
    border-width: 1px;
    property <bool> hovered: touch.has-hover;
    property <bool> pressed: touch.pressed;
    property <color> icon-color: pressed ? Palette.accent-background : (hovered ? Palette.foreground : Palette.control-foreground);
    background: pressed ? Palette.control-background.darker(0.22) : (hovered ? Palette.control-background.darker(0.1) : Palette.control-background.darker(0.03));
    border-color: hovered ? Palette.foreground.darker(0.45) : Palette.foreground.darker(0.7);
    drop-shadow-blur: hovered ? 8px : 4px;
    animate background {
        duration: 120ms;
        easing: ease-out-quad;
    }
    animate border-color {
        duration: 120ms;
        easing: ease-out-quad;
    }
    animate drop-shadow-blur {
        duration: 120ms;
        easing: ease-out-quad;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        width: 100%;
        height: 100%;
        clicked => {
            root.clicked();
        }
    }

    Path {
        x: parent.width * 0.12;
        y: parent.height * 0.12;
        width: parent.width * 0.76;
        height: parent.height * 0.76;
        viewbox-width: 24;
        viewbox-height: 24;
        fill: transparent;
        commands: "M6.029 4.285A2 2 0 0 0 3 6v12a2 2 0 0 0 3.029 1.715l9.997-5.998a2 2 0 0 0 .003-3.432z";
        stroke: root.icon-color;
        stroke-width: 2.3px;
        stroke-line-cap: round;
    }

    Path {
        x: parent.width * 0.12;
        y: parent.height * 0.12;
        width: parent.width * 0.76;
        height: parent.height * 0.76;
        viewbox-width: 24;
        viewbox-height: 24;
        fill: transparent;
        commands: "M21 4v16";
        stroke: root.icon-color;
        stroke-width: 2.3px;
        stroke-line-cap: round;
    }
}

