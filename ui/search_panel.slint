import { Theme } from "theme.slint";
import { LineEdit } from "std-widgets.slint";
import { ListView } from "std-widgets.slint";
import { SongItem } from "song_list.slint";
import { SongInfo, TriggerSource } from "types.slint";

export component SearchPanel inherits Rectangle {
    in-out property <string> search-query;
    in property <[SongInfo]> all-songs;
    in property <[SongInfo]> search-results;
    in property <SongInfo> current-song;
    callback search(string);
    callback play-song(SongInfo, TriggerSource);

    background: Theme.surface;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;

        // Search bar
        Rectangle {
            height: 40px;
            width: 100%;
            background: Theme.surface;

            HorizontalLayout {
                width: 100%;
                height: 100%;
                spacing: 8px;
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 8px;
                padding-bottom: 8px;

                search-input := LineEdit {
                    horizontal-stretch: 1;
                    height: 100%;
                    placeholder-text: @tr("Search songs or artists...");
                    text <=> root.search-query;
                    font-size: 13px;

                    edited => {
                        root.search(self.text);
                    }
                }

                // Clear button
                clear-btn := Rectangle {
                    width: 28px;
                    height: 100%;
                    border-radius: 4px;
                    background: clear-touch.has-hover ? Theme.hover : transparent;

                    Path {
                        width: 16px;
                        height: 16px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        viewbox-width: 24;
                        viewbox-height: 24;
                        commands: "M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z";
                        fill: Theme.text-secondary;
                    }

                    clear-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.search-query = "";
                            root.search("");
                        }
                    }
                }
            }
        }

        // Divider
        Rectangle {
            height: 1px;
            width: 100%;
            background: Theme.divider;
        }

        // Results count label
        Rectangle {
            height: 26px;
            width: 100%;
            background: Theme.surface;
            visible: root.search-query != "";

            Text {
                x: 12px;
                y: (parent.height - self.height) / 2;
                text: root.search-results.length == 0
                    ? @tr("No results found")
                    : @tr("%1 result(s) found", root.search-results.length);
                color: Theme.text-tertiary;
                font-size: 12px;
                vertical-alignment: center;
            }
        }

        // Results list
        ListView {
            horizontal-stretch: 1;
            visible: root.search-query != "";

            for item in root.search-results: SongItem {
                info: item;
                playing: item.song-path == root.current-song.song-path;
                double_clicked => {
                    root.play-song(item, TriggerSource.ClickItem);
                }
            }
        }

        // Empty state - show hint when no query
        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            visible: root.search-query == "";

            VerticalLayout {
                width: 100%;
                height: 100%;
                alignment: center;
                spacing: 8px;

                Path {
                    width: 48px;
                    height: 48px;
                    x: (parent.width - self.width) / 2;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    commands: "M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z";
                    fill: Theme.text-tertiary;
                }

                Text {
                    text: @tr("Type to search songs");
                    color: Theme.text-tertiary;
                    font-size: 14px;
                    horizontal-alignment: center;
                }

                Text {
                    text: @tr("Press F5 to open search");
                    color: Theme.text-tertiary;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
