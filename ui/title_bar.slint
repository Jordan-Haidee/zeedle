import { Palette } from "std-widgets.slint";

export component TitleBar inherits Rectangle {
    in-out property <bool> is_light_theme: false;
    in-out property <bool> theme_toggle_enabled: true;
    callback close;
    callback minimize;
    callback maximize;
    callback toggle_theme;
    callback drag_delta(float, float);
    height: 36px;
    background: Palette.background;

    // Drag area - entire title bar
    TouchArea {
        width: parent.width;
        height: parent.height;
        moved => {
            if (self.pressed) {
                root.drag_delta(
                    (self.mouse-x - self.pressed-x) / 1px,
                    (self.mouse-y - self.pressed-y) / 1px);
            }
        }
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;

        // App title (left side)
        Rectangle {
            width: 130px;
            Image {
                source: @image-url("cover.svg");
                width: 18px;
                height: 18px;
                x: 10px;
                y: (parent.height - self.height) / 2;
            }

            Text {
                x: 34px;
                y: (parent.height - self.height) / 2;
                text: "Zeedle";
                font-size: 13px;
                font-weight: 600;
                color: Palette.foreground;
                vertical-alignment: center;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        // Theme toggle button
        title-theme := Rectangle {
            width: 42px;
            height: 100%;
            opacity: root.theme_toggle_enabled ? 1.0 : 0.4;
            background: (root.theme_toggle_enabled && theme-touch.has-hover) ? Palette.control-background.darker(0.08) : transparent;
            animate background { duration: 100ms; }
            Image {
                source: root.is_light_theme ? @image-url("sun.svg") : @image-url("moon.svg");
                colorize: (root.theme_toggle_enabled && theme-touch.has-hover) ? Palette.foreground : Palette.foreground.darker(0.15);
                width: 18px;
                height: 18px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }

            theme-touch := TouchArea {
                enabled: root.theme_toggle_enabled;
                mouse-cursor: pointer;
                clicked => { root.toggle_theme(); }
            }
        }

        Rectangle {
            width: 1px;
            height: 16px;
            y: (parent.height - self.height) / 2;
            background: Palette.foreground.darker(0.75);
        }

        // Minimize button
        btn-min := Rectangle {
            width: 42px;
            height: 100%;
            background: min-touch.has-hover ? Palette.control-background.darker(0.08) : transparent;
            animate background { duration: 100ms; }
            Rectangle {
                width: 12px;
                height: 2px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: 1px;
                background: min-touch.has-hover ? Palette.foreground : Palette.foreground.darker(0.15);
            }

            min-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.minimize(); }
            }
        }

        // Maximize/Restore button
        btn-max := Rectangle {
            width: 42px;
            height: 100%;
            background: max-touch.has-hover ? Palette.control-background.darker(0.08) : transparent;
            animate background { duration: 100ms; }
            Rectangle {
                width: 10px;
                height: 10px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-width: 1.5px;
                border-color: max-touch.has-hover ? Palette.foreground : Palette.foreground.darker(0.15);
                border-radius: 1px;
            }

            max-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.maximize(); }
            }
        }

        // Close button
        btn-close := Rectangle {
            width: 42px;
            height: 100%;
            background: close-touch.has-hover ? #e81123 : transparent;
            animate background { duration: 100ms; }
            Path {
                x: (parent.width - 12px) / 2;
                y: (parent.height - 12px) / 2;
                width: 12px;
                height: 12px;
                viewbox-width: 12;
                viewbox-height: 12;
                stroke: close-touch.has-hover ? white : Palette.foreground.darker(0.15);
                stroke-width: 1.5px;
                stroke-line-cap: round;
                commands: "M 1 1 L 11 11 M 11 1 L 1 11";
            }

            close-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.close(); }
            }
        }
    }
}
