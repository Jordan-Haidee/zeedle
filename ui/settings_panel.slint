import { Theme } from "theme.slint";
import {
    Button,
    CheckBox,
    Palette,
} from "std-widgets.slint";

component LangButton inherits Rectangle {
    in property <string> lang-code;
    in property <string> current-lang;
    in property <string> text;
    callback clicked(string);
    border-radius: 4px;
    border-width: 1px;
    border-color: lang-code == current-lang ? Theme.accent : Theme.border;
    background: lang-code == current-lang ? Theme.accent : Theme.hover;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 4px;
        padding-bottom: 4px;
        alignment: center;
        Text {
            text: root.text;
            color: lang-code == current-lang ? Theme.surface : Theme.text;
            font-size: 13px;
        }
    }

    TouchArea {
        clicked => { root.clicked(lang-code); }
    }
}

export component SettingsPanel inherits Rectangle {
    in-out property <string> song_dir;
    in-out property <string> lang;
    in-out property <bool> follow_system_theme;
    in-out property <bool> show_spectrum;
    callback refresh_song_list(string);
    callback set_lang(string);
    callback set_follow_system_theme(bool);
    callback set_show_spectrum(bool);
    callback select_song_dir();
    background: Theme.surface;

    Flickable {
        width: 100%;
        height: 100%;
        viewport-height: layout.preferred-height;
        interactive: true;

        layout := VerticalLayout {
            width: 100%;
            padding: 24px;
            spacing: 20px;

            // --- Playback Section ---
            Rectangle {
                background: Theme.panel;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.border;

                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: @tr("Playback");
                        font-size: 12px;
                        font-weight: 600;
                        color: Theme.text-tertiary;
                        letter-spacing: 0.3px;
                    }

                    Rectangle {
                        height: 1px;
                        background: Theme.divider;
                    }

                    // Music directory
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: @tr("Music directory");
                            font-size: 13px;
                            color: Theme.text-secondary;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: Theme.border;
                                background: Theme.hover;
                                horizontal-stretch: 1;
                                clip: true;
                                Text {
                                    x: 12px;
                                    width: parent.width - 24px;
                                    height: 100%;
                                    text: root.song_dir;
                                    color: Theme.text-secondary;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            Button {
                                text: @tr("Browse...");
                                clicked => {
                                    root.select_song_dir();
                                }
                            }
                        }
                    }

                    // Spectrum display
                    CheckBox {
                        text: @tr("Spectrum display");
                        checked <=> root.show_spectrum;
                        toggled => {
                            root.set_show_spectrum(self.checked);
                        }
                    }
                }
            }

            // --- Appearance Section ---
            Rectangle {
                background: Theme.panel;
                border-radius: 8px;
                border-width: 1px;
                border-color: Theme.border;

                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: @tr("Appearance");
                        font-size: 12px;
                        font-weight: 600;
                        color: Theme.text-tertiary;
                        letter-spacing: 0.3px;
                    }

                    Rectangle {
                        height: 1px;
                        background: Theme.divider;
                    }

                    // Follow system theme
                    CheckBox {
                        text: @tr("Follow system theme");
                        checked <=> root.follow_system_theme;
                        toggled => {
                            root.set_follow_system_theme(self.checked);
                        }
                    }

                    // Language
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: @tr("Language");
                            font-size: 13px;
                            color: Theme.text-secondary;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            for lc[i] in ["", "zh_CN", "es", "fr", "de", "ru"]: LangButton {
                                lang-code: lc;
                                current-lang: root.lang;
                                text: lc == "" ? "English" :
                                    lc == "zh_CN" ? "中文" :
                                    lc == "es" ? "Español" :
                                    lc == "fr" ? "Français" :
                                    lc == "de" ? "Deutsch" :
                                    "Русский";
                                clicked(code) => { root.lang = code; root.set_lang(code); }
                            }
                        }
                    }
                }
            }
        }
    }
}
