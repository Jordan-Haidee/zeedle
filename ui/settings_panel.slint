import {
    CheckBox,
    ComboBox,
    LineEdit,
    Palette,
} from "std-widgets.slint";

export component SettingsPanel inherits Rectangle {
    in-out property <string> song_dir;
    in-out property <string> lang;
    in-out property <bool> follow_system_theme;
    in-out property <bool> show_spectrum;
    callback refresh_song_list(string);
    callback set_lang(string);
    callback set_follow_system_theme(bool);
    callback set_show_spectrum(bool);
    callback select_song_dir();

    Flickable {
        width: 100%;
        height: 100%;
        viewport-height: layout.preferred-height;
        interactive: true;

        layout := VerticalLayout {
            width: 100%;
            padding: 24px;
            spacing: 20px;

            // --- Playback Section ---
            Rectangle {
                background: Palette.control-background.darker(0.035);
                border-radius: 8px;
                border-width: 1px;
                border-color: Palette.foreground.with-alpha(0.15);

                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: @tr("Playback");
                        font-size: 12px;
                        font-weight: 600;
                        color: Palette.foreground.with-alpha(0.55);
                        letter-spacing: 0.3px;
                    }

                    Rectangle {
                        height: 1px;
                        background: Palette.foreground.with-alpha(0.1);
                    }

                    // Music directory
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: @tr("Music directory");
                            font-size: 13px;
                            color: Palette.foreground.with-alpha(0.65);
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: Palette.foreground.with-alpha(0.15);
                                background: Palette.control-background.darker(0.06);
                                horizontal-stretch: 1;
                                clip: true;
                                Text {
                                    x: 12px;
                                    width: parent.width - 24px;
                                    height: 100%;
                                    text: root.song_dir;
                                    color: Palette.foreground.with-alpha(0.7);
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                height: 32px;
                                min-width: 100px;
                                border-radius: 4px;
                                background: btn-touch.has-hover ? Palette.accent-background.darker(0.08) : Palette.accent-background;
                                animate background { duration: 100ms; }
                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    spacing: 6px;
                                    alignment: center;
                                    Text {
                                        text: @tr("Browse...");
                                        color: Palette.accent-foreground;
                                        font-size: 13px;
                                        font-weight: 500;
                                        vertical-alignment: center;
                                    }
                                }

                                btn-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.select_song_dir();
                                    }
                                }
                            }
                        }
                    }

                    // Spectrum display
                    CheckBox {
                        text: @tr("Spectrum display");
                        checked <=> root.show_spectrum;
                        toggled => {
                            root.set_show_spectrum(self.checked);
                        }
                    }
                }
            }

            // --- Appearance Section ---
            Rectangle {
                background: Palette.control-background.darker(0.035);
                border-radius: 8px;
                border-width: 1px;
                border-color: Palette.foreground.with-alpha(0.15);

                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: @tr("Appearance");
                        font-size: 12px;
                        font-weight: 600;
                        color: Palette.foreground.with-alpha(0.55);
                        letter-spacing: 0.3px;
                    }

                    Rectangle {
                        height: 1px;
                        background: Palette.foreground.with-alpha(0.1);
                    }

                    // Follow system theme
                    CheckBox {
                        text: @tr("Follow system theme");
                        checked <=> root.follow_system_theme;
                        toggled => {
                            root.set_follow_system_theme(self.checked);
                        }
                    }

                    // Language
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: @tr("Language");
                            font-size: 13px;
                            color: Palette.foreground.with-alpha(0.65);
                        }

                        ComboBox {
                            current-value <=> root.lang;
                            model: ["", "zh_CN", "es", "fr", "de", "ru"];
                            selected(current-value) => {
                                root.set_lang(current-value);
                            }
                        }
                    }
                }
            }
        }
    }
}
